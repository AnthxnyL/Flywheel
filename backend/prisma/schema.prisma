// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DRIVER
  DEALER
  BRAND
}

enum ContractType {
  LOA
  LLD
}

model User {
  id                     String                   @id @default(cuid())
  email                  String                   @unique
  password               String?
  role                   Role
  emailVerified          Boolean                  @default(false)
  emailVerificationToken String?                  @unique
  passwordResetToken     String?                  @unique
  passwordResetExpires   DateTime?
  createdAt              DateTime                 @default(now())
  vehicles               Vehicle[]
  mileageRecords         MileageRecord[]
  notificationPreference NotificationPreference?
  pushSubscriptions      PushSubscription[]
  logEntries             VehicleLogEntry[]
  invoices               Invoice[]
}

model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  emailEnabled Boolean  @default(true)
  pushEnabled  Boolean  @default(false)
  remindJ30    Boolean  @default(true)
  remindJ7     Boolean  @default(true)
  remindJ1     Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
}

model Vehicle {
  id                 String               @id @default(cuid())
  vin                String               @unique
  brand              String
  model              String
  year               Int?
  licensePlate       String?
  mileage            Int
  initialMileage     Int                  @default(0)
  driver             User?                @relation(fields: [driverId], references: [id])
  driverId           String?
  createdAt          DateTime             @default(now())
  contracts          Contract[]
  maintenanceRecords MaintenanceRecord[]
  mileageRecords     MileageRecord[]
  maintenancePlan    MaintenancePlanItem[]
  logEntries         VehicleLogEntry[]
  invoices           Invoice[]
}

enum LogEntryType {
  MAINTENANCE
  REPAIR
  INSPECTION
  RECALL
  MILEAGE_UPDATE
  DOCUMENT
  NOTE
}

model VehicleLogEntry {
  id          String       @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle      @relation(fields: [vehicleId], references: [id])
  type        LogEntryType
  date        DateTime
  title       String
  description String?
  mileageAtEvent Int?
  cost        Float?
  documentUrl String?
  createdBy   User?        @relation(fields: [createdById], references: [id])
  createdById String?
  createdAt   DateTime     @default(now())
}

model MileageRecord {
  id           String   @id @default(cuid())
  mileage      Int
  recordedAt   DateTime @default(now())
  note         String?
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])
  vehicleId    String
  recordedBy   User?    @relation(fields: [recordedById], references: [id])
  recordedById String?
}

model Contract {
  id           String       @id @default(cuid())
  type         ContractType
  startDate    DateTime
  endDate      DateTime
  mileageLimit Int
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id])
  vehicleId    String
}

model MaintenanceRecord {
  id         String   @id @default(cuid())
  date       DateTime
  type       String
  cost       Float
  invoiceUrl String?
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  vehicleId  String
}

// One row per operation type per vehicle (oil change, brakes, timing belt…)
// Stores the recurrence rule + last execution → system derives next due date/km
model Invoice {
  id           String   @id @default(cuid())
  vehicleId    String
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  label        String?
  invoiceDate  DateTime?
  amount       Float?
  filename     String
  storedName   String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())
}

model MaintenancePlanItem {
  id              String    @id @default(cuid())
  vehicleId       String
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id])
  operationType   String    // "Vidange", "Freins avant", "Courroie de distribution"…
  dueDate         DateTime? // fixed deadline set by dealer
  intervalKm      Int?      // recur every X km  (null = time-only)
  intervalMonths  Int?      // recur every X months (null = mileage-only)
  lastDoneKm      Int?      // km reading when last performed
  lastDoneDate    DateTime? // date when last performed
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
