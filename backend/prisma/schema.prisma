// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DRIVER
  DEALER
  BRAND
}

enum ContractType {
  LOA
  LLD
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  password               String?   // null until the client activates their account
  role                   Role
  emailVerified          Boolean   @default(false)
  emailVerificationToken String?   @unique
  passwordResetToken     String?   @unique
  passwordResetExpires   DateTime?
  createdAt              DateTime  @default(now())
  vehicles               Vehicle[]
}

model Vehicle {
  id                 String              @id @default(cuid())
  vin                String              @unique
  brand              String
  model              String
  mileage            Int
  driver             User                @relation(fields: [driverId], references: [id])
  driverId           String
  contracts          Contract[]
  maintenanceRecords MaintenanceRecord[]
}

model Contract {
  id           String       @id @default(cuid())
  type         ContractType
  startDate    DateTime
  endDate      DateTime
  mileageLimit Int
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id])
  vehicleId    String
}

model MaintenanceRecord {
  id         String   @id @default(cuid())
  date       DateTime
  type       String
  cost       Float
  invoiceUrl String?
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  vehicleId  String
}
