// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DRIVER
  DEALER
  BRAND
}

enum ContractType {
  LOA
  LLD
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  role      Role
  createdAt DateTime  @default(now())
  vehicles  Vehicle[]
}

model Vehicle {
  id                 String              @id @default(cuid())
  vin                String              @unique
  brand              String
  model              String
  mileage            Int
  driver             User                @relation(fields: [driverId], references: [id])
  driverId           String
  contracts          Contract[]
  maintenanceRecords MaintenanceRecord[]
}

model Contract {
  id            String       @id @default(cuid())
  type          ContractType
  startDate     DateTime
  endDate       DateTime
  mileageLimit  Int
  vehicle       Vehicle      @relation(fields: [vehicleId], references: [id])
  vehicleId     String
}

model MaintenanceRecord {
  id         String   @id @default(cuid())
  date       DateTime
  type       String
  cost        Float
  invoiceUrl String?
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  vehicleId  String
}
