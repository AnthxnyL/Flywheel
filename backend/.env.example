DATABASE_URL="postgresql://postgres:password@localhost:5432/flywheel_dev"
JWT_SECRET="change-me-in-production"
PORT=3000

# JWT — use a long random string in production
JWT_ACCESS_SECRET="access-secret-change-me"
JWT_REFRESH_SECRET="refresh-secret-change-me"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# SMTP — configure with your email provider
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-pass"
SMTP_FROM="noreply@flywheel.app"

# Public URL of the frontend
APP_URL="http://localhost:5173"